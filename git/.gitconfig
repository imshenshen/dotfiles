[push]
  default = simple
[user]
  name = shenshen
  email = im.shenshen@qq.com
  #signingKey = D44B865A0CB3B59D
[core]
  editor = nvim
  ignorecase = false
  autocrlf = input
  excludesfile = ~/.gitignore
  ;pager = diff-so-fancy | less --tabs=4 -RFX --pattern '^(Date|added|deleted|modified): '
[alias]
  st = status
  ci = commit
  co = checkout
  br = branch
  last = log -2 HEAD

  lg = !"git lg1-specific --all"
  lg1-specific = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %s - %an%C(reset)%C(bold yellow)%d%C(reset)'
	dsf = "!f() { [ -z \"$GIT_PREFIX\" ] || cd \"$GIT_PREFIX\" && git diff --color \"$@\" | diff-so-fancy  | less --tabs=4 -RFX --pattern \"^(Date|added|deleted|modified): \"; }; f"
	wta = "!f() {\n  set -e\n\n  if [ -z \"$1\" ]; then\n    echo \"Usage: git wta origin/<branch>   (or <branch> treated as origin/<branch>)\" >&2\n    return 2\n  fi\n\n  branch=\"$1\"\n  case \"$branch\" in\n    origin/*) ;;\n    *) branch=\"origin/$branch\" ;;\n  esac\n\n  repo=\"$(basename \"$(pwd)\")\"\n  local_branch=\"${branch#origin/}\"\n\n  clean_branch=\"$(printf \"%s\" \"$local_branch\" | tr \"/\" \"-\")\"\n  dir=\"../${repo}-${clean_branch}\"\n\n  if [ -e \"$dir\" ]; then\n    echo \"Error: target directory already exists: $dir\" >&2\n    return 1\n  fi\n\n  # ensure remote exists locally (fetch once if needed)\n  if ! git show-ref --verify --quiet \"refs/remotes/$branch\"; then\n    echo \"Info: remote ref not found locally ($branch), fetching origin...\" >&2\n    git fetch origin --prune >&2 || true\n  fi\n  if ! git show-ref --verify --quiet \"refs/remotes/$branch\"; then\n    echo \"Error: remote branch not found: $branch\" >&2\n    return 1\n  fi\n\n  # local branch already exists?\n  if git show-ref --verify --quiet \"refs/heads/$local_branch\"; then\n    echo \"Error: local branch already exists: $local_branch\" >&2\n    echo \"Hint: if you want to reuse it, run: git worktree add \\\"$dir\\\" \\\"$local_branch\\\"\" >&2\n    return 1\n  fi\n\n  echo \"Creating worktree:\"\n  echo \"  remote: $branch\"\n  echo \"  local:  $local_branch (tracking)\"\n  echo \"  dir:    $dir\"\n\n  git worktree add --track -b \"$local_branch\" \"$dir\" \"$branch\"\n}; f"
	wtr = "!f() {\n  set -e\n\n  if [ -z \"$1\" ]; then\n    echo \"Usage: git wtr origin/<branch>   (or <branch> treated as origin/<branch>)\" >&2\n    return 2\n  fi\n\n  branch=\"$1\"\n  case \"$branch\" in\n    origin/*) ;;\n    *) branch=\"origin/$branch\" ;;\n  esac\n\n  repo=\"$(basename \"$(pwd)\")\"\n  local_branch=\"${branch#origin/}\"\n  clean_branch=\"$(printf \"%s\" \"$local_branch\" | tr \"/\" \"-\")\"\n  dir=\"../${repo}-${clean_branch}\"\n\n  if [ ! -d \"$dir\" ]; then\n    echo \"Error: directory does not exist: $dir\" >&2\n    echo \"Hint: run: ls .. | grep -F \\\"${repo}-${clean_branch}\\\"\" >&2\n    return 1\n  fi\n\n  # Canonical absolute path (matches git worktree list --porcelain)\n  abs_dir=\"$(cd \"$dir\" && pwd -P)\"\n\n  if ! git worktree list --porcelain | grep -Fxq \"worktree $abs_dir\"; then\n    echo \"Warning: worktree path not found in git metadata: $abs_dir\" >&2\n    echo \"Hint: run: git worktree list\" >&2\n    echo \"Trying to remove anyway...\" >&2\n  fi\n\n  echo \"Removing worktree: $abs_dir\"\n  git worktree remove --force \"$abs_dir\"\n\n  # Try delete local branch if exists and not used elsewhere\n  if git worktree list --porcelain | grep -q \"^branch refs/heads/$local_branch$\"; then\n    echo \"Info: local branch still used by another worktree, not deleting: $local_branch\" >&2\n    return 0\n  fi\n\n  if git show-ref --verify --quiet \"refs/heads/$local_branch\"; then\n    echo \"Deleting local branch: $local_branch\"\n    git branch -D \"$local_branch\" >/dev/null\n  fi\n}; f"

[color]
  ui = true

[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22

[color "diff"]
  meta = yellow
  frag = magenta bold
  commit = yellow bold
  old = red bold
  new = green bold
  whitespace = red reverse

[includeIf "gitdir:~/Documents/jingdong/gitlab/"] # MBP 16
  path = ~/Documents/jingdong/gitlab/jingdong.inc

[includeIf "gitdir:~/code/jingdong/gitlab/"] # MPB 14
  path = ~/code/jingdong/gitlab/jingdong.inc

[https]
;proxy = https://127.0.0.1:6152
[http]
;proxy = http://127.0.0.1:6152

[http "https://github.com"]
  ; proxy = socks5://127.0.0.1:6153

[commit]
	;gpgSign = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[pull]
	rebase = true
